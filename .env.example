# Environment
APP_ENV=development

# Server
PORT=4000

# Database
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=medcord

# JWT
JWT_SECRET=change-me-in-production-this-must-be-at-least-32-chars
JWT_EXPIRES_IN=168h

# Cache
CACHE_SIZE=4096

# Rate limiting
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_MAX=100

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
